  "name": "Ali Mohamed",
  "grade": "KG1",
  "studentId": "STU001",
  "birthDay": "2019-05-15",
  "userName": "student_ali",
  "password": "pass123",
  "phoneNumber": "01112233445",
  "whatsApp": "01112233445",
  "dressCode": "Blue uniform"
}

### Expected Response ✅
# Status: 201
# {
#   "message": "Student added successfully",
#   "student": {
#     "_id": "65f1b3...",
#     "name": "Ali Mohamed",
#     "grade": "KG1",
#     "studentId": "STU001",
#     "birthDay": "2019-05-15T00:00:00.000Z",
#     "isDeleted": false,
#     "evaluations": [],
#     "payments": [],
#     "createdAt": "..."
#   }
# }

###

### [11] Get All Students 📋
GET {{baseUrl}}/admin/students
Authorization: Bearer {{adminToken}}

### Expected Response ✅
# — يرجع فقط الطلاب اللي isDeleted: false
# [
#   {
#     "_id": "65f1b3...",
#     "name": "Ali Mohamed",
#     "missId": { "name": "Sarah Ahmed", "specialty": "Arabic Language" },
#     ...
#   }
# ]

###

### [12] Get Student by ID 🔍
GET {{baseUrl}}/admin/students/{{studentId}}
Authorization: Bearer {{adminToken}}

### Expected Response ✅
# { "_id": "...", "name": "Ali Mohamed", "grade": "KG1", ... }

###

### [13] Update Student ✏️
PUT {{baseUrl}}/admin/students/{{studentId}}
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "grade": "KG2",
  "dressCode": "Red uniform"
}

### Expected Response ✅
# {
#   "message": "Student updated successfully",
#   "student": { "_id": "...", "grade": "KG2", ... }
# }

###

### [14] Delete Student (Soft Delete) 🗑️
DELETE {{baseUrl}}/admin/students/{{studentId}}
Authorization: Bearer {{adminToken}}

### Expected Response ✅
# { "message": "Student deleted successfully" }
# ملاحظة: الطالب مش بيتحذف فعلياً — بس isDeleted بتبقى true


