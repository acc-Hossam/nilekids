### ============================================================
### 🔐 AUTH - LOGIN
### ============================================================

### [1] Login as Admin
# @name loginAdmin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin123",
  "role": "admin"
}

### Expected Response ✅
# {
#   "token": "eyJhbGciOiJIUzI1...",
#   "role": "admin",
#   "userId": "65f1a2b3c4d5e6f7a8b9c0d1"
# }

###

### [2] Login as Teacher
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "teacher_sarah",
  "password": "pass123",
  "role": "teacher"
}

### Expected Response ✅
# {
#   "token": "eyJhbGciOiJIUzI1...",
#   "role": "teacher",
#   "userId": "65f1a2b3c4d5e6f7a8b9c0d2"
# }

###

### [3] Login as Student
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "student_ali",
  "password": "pass123",
  "role": "student"
}

### Expected Response ✅
# {
#   "token": "eyJhbGciOiJIUzI1...",
#   "role": "student",
#   "userId": "65f1a2b3c4d5e6f7a8b9c0d3"
# }

###

### [4] Login - Wrong Password ❌
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "wrongpassword",
  "role": "admin"
}

### Expected Response ❌
# Status: 401
# { "message": "Invalid credentials" }


### ============================================================
### 👩‍🏫 ADMIN - TEACHERS
### ============================================================

### [5] Add New Teacher ➕
POST {{baseUrl}}/admin/teachers
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "name": "Sarah Ahmed",
  "username": "teacher_sarah",
  "specialty": "Arabic Language",
  "contact": {
    "phone": "01012345678",
    "email": "sarah@nilekids.com"
  },
  "password": "pass123"
}

### Expected Response ✅
# Status: 201
# {
#   "message": "Teacher added successfully",
#   "teacher": {
#     "_id": "65f1a2...",
#     "name": "Sarah Ahmed",
#     "specialty": "Arabic Language",
#     "contact": { "phone": "01012345678", "email": "sarah@nilekids.com" },
#     "classIds": [],
#     "subjectIds": [],
#     "createdAt": "2025-01-01T00:00:00.000Z"
#   }
# }

###

### [6] Get All Teachers 📋
GET {{baseUrl}}/admin/teachers
Authorization: Bearer {{adminToken}}

### Expected Response ✅
# [
#   {
#     "_id": "65f1a2...",
#     "name": "Sarah Ahmed",
#     "specialty": "Arabic Language",
#     ...
#   }
# ]

###

### [7] Get Teacher by ID 🔍
GET {{baseUrl}}/admin/teachers/{{teacherId}}
Authorization: Bearer {{adminToken}}

### Expected Response ✅
# {
#   "_id": "65f1a2...",
#   "name": "Sarah Ahmed",
#   ...
# }

### Expected if not found ❌
# Status: 404
# { "message": "Teacher not found" }

###

### [8] Update Teacher ✏️
PUT {{baseUrl}}/admin/teachers/{{teacherId}}
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "specialty": "Mathematics",
  "contact": {
    "phone": "01098765432",
    "email": "sarah.new@nilekids.com"
  }
}

### Expected Response ✅
# {
#   "message": "Teacher updated successfully",
#   "teacher": { "_id": "65f1a2...", "specialty": "Mathematics", ... }
# }

###

### [9] Delete Teacher 🗑️
DELETE {{baseUrl}}/admin/teachers/{{teacherId}}
Authorization: Bearer {{adminToken}}

### Expected Response ✅
# { "message": "Teacher deleted successfully" }


